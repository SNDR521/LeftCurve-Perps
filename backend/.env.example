# --- Required ---
SECRET_KEY=change-me-run-openssl-rand-hex-32
SESSION_SECRET=change-me-too-run-openssl-rand-hex-32

# --- Database (optional; defaults to a local SQLite file at backend/trades.db) ---
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/leftcurve

# --- Frontend / CORS (defaults for local dev) ---
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- RiseX (on-chain perps DEX; no key required — public read endpoints) ---
RISEX_API_BASE=https://api.rise.trade

# --- News (optional; free key at finnhub.io — News is empty without it) ---
# FINNHUB_API_KEY=

# --- Telegram alarms (optional; create a bot via @BotFather, then Settings -> Telegram) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET=
